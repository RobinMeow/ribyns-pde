#!/usr/bin/env bash

# ribyn - Entry point for Robin's PDE scripts

# Resolve the project root
if [[ -z "${PDE}" ]]; then
	export PDE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

# Source utils for colors and logging
if [[ -f "$PDE/scripts/utils.sh" ]]; then
	source "$PDE/scripts/utils.sh"
else
	# Fallback colors if utils.sh is missing
	CATBLUE="\033[38;5;109m"
	CATGREEN="\033[38;5;114m"
	CATRED="\033[38;5;203m"
	NC="\033[0m"
	info() { echo -e "${CATBLUE}[INFO]${NC} $*"; }
	success() { echo -e "${CATGREEN}[SUCCESS]${NC} $*"; }
	error() { echo -e "${CATRED}[ERROR]${NC} $*"; }
fi

usage() {
	echo -e "${CATBLUE}ribyn${NC} - Robin's PDE Script Entry Point"
	echo ""
	echo "Usage:"
	echo "  ribyn [script_name] [args...]   Run a specific script"
	echo "  ribyn --list                    List all available scripts"
	echo "  ribyn --help                    Show this help"
	echo ""
	echo "If no script name is provided, an interactive menu will be shown."
}

list_scripts() {
	# List all .sh files, but filter out common library/utility scripts
	find "$PDE/scripts" -maxdepth 1 -name "*.sh" -not -name "utils.sh" -not -name "os-detect.sh" -printf "%f\n" |
		sed 's/\.sh$//' |
		sort
}

# Check if an argument is provided
if [[ $# -eq 0 ]]; then
	# Interactive mode with fzf
	if command -v fzf >/dev/null 2>&1; then
		script=$(list_scripts | fzf --prompt="Select a script to run: " --height=40% --reverse --border)
		if [[ -n "$script" ]]; then
			"$PDE/scripts/${script}.sh"
		fi
	else
		usage
		echo ""
		echo -e "${CATBLUE}Available scripts:${NC}"
		list_scripts | column
	fi
	exit 0
fi

case "$1" in
--help | -h | help)
	usage
	exit 0
	;;
--list | -l | list)
	list_scripts
	exit 0
	;;
*)
	# Check if the script exists
	script_name="$1"
	# Remove .sh suffix if provided to avoid duplication
	script_name="${script_name%.sh}"

	if [[ -f "$PDE/scripts/${script_name}.sh" ]]; then
		shift
		"$PDE/scripts/${script_name}.sh" "$@"
	else
		error "Script '${script_name}' not found in $PDE/scripts/"
		echo "Use 'ribyn --list' to see available scripts."
		exit 1
	fi
	;;
esac
