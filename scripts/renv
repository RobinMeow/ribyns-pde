#!/usr/bin/env bash

# renv - Ribyn's Environment CLI dispatcher

# Resolve the project root
if [[ -z "${RIBYNS_ENV}" ]]; then
	export RIBYNS_ENV="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

# Source utils for colors and logging
if [[ -f "$RIBYNS_ENV/scripts/utils.sh" ]]; then
	source "$RIBYNS_ENV/scripts/utils.sh"
else
	CATBLUE="\033[38;5;109m"; CATGREEN="\033[38;5;114m"; CATRED="\033[38;5;203m"; NC="\033[0m"
	info() { echo -e "${CATBLUE}[INFO]${NC} $*"; }
	success() { echo -e "${CATGREEN}[SUCCESS]${NC} $*"; }
	error() { echo -e "${CATRED}[ERROR]${NC} $*"; }
fi

usage() {
	echo -e "${CATBLUE}renv${NC} - Ribyn's Environment CLI"
	echo ""
	echo "Usage:"
	echo "  renv install <app>    Install a component (e.g., nvim, wezterm)"
	echo "  renv build <app>      Build from source (e.g., hyprland, neovim)"
	echo "  renv pm <group>       Run package manager scripts (e.g., core, webdev)"
	echo "  renv setup            Run the main setup-linux.sh"
	echo "  renv list             List all available scripts and components"
	echo "  renv help             Show this help"
	echo ""
	echo "Shortcut: Run 'renv' without arguments for an interactive menu."
}

# Helper to find and run scripts with flexible naming
dispatch() {
	local prefix="$1"
	local target="$2"
	shift 2

	local patterns=(
		"$RIBYNS_ENV/scripts/${prefix}-${target}.sh"
		"$RIBYNS_ENV/scripts/${prefix}_${target}.sh"
		"$RIBYNS_ENV/scripts/${target}.sh"
	)

	for script in "${patterns[@]}"; do
		if [[ -f "$script" ]]; then
			"$script" "$@"
			return $?
		fi
	done

	error "Could not find script for: ${prefix} ${target}"
	return 1
}

# Subcommands
case "$1" in
install)
	shift
	if [[ -z "$1" ]]; then
		echo -e "${CATBLUE}Available for install:${NC}"
		find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "install-*.sh" -o -name "install_*.sh" | sed -E 's/.*install[-_](.*)\.sh/\1/' | sort | column
	else
		dispatch "install" "$@"
	fi
	;;
build)
	shift
	if [[ -z "$1" ]]; then
		echo -e "${CATBLUE}Available to build from source:${NC}"
		find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "build-*-from-source.sh" | sed -E 's/.*build-(.*)-from-source\.sh/\1/' | sort | column
	else
		# Special handling for the '-from-source' suffix
		if [[ -f "$RIBYNS_ENV/scripts/build-$1-from-source.sh" ]]; then
			script="$RIBYNS_ENV/scripts/build-$1-from-source.sh"
			shift
			"$script" "$@"
		else
			error "Build script for '$1' not found."
		fi
	fi
	;;
pm)
	shift
	if [[ -z "$1" ]]; then
		echo -e "${CATBLUE}Available PM groups:${NC}"
		find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "pm-*.sh" | sed -E 's/.*pm-(.*)\.sh/\1/' | sort | column
	else
		dispatch "pm" "$@"
	fi
	;;
setup)
	"$RIBYNS_ENV/scripts/setup-linux.sh" "${@:2}"
	;;
list)
	echo -e "${CATBLUE}--- Installable ---${NC}"
	find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "install-*.sh" -o -name "install_*.sh" | sed -E 's/.*install[-_](.*)\.sh/\1/' | sort | column
	echo -e "\n${CATBLUE}--- Source Builds ---${NC}"
	find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "build-*-from-source.sh" | sed -E 's/.*build-(.*)-from-source\.sh/\1/' | sort | column
	echo -e "\n${CATBLUE}--- PM Groups ---${NC}"
	find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "pm-*.sh" | sed -E 's/.*pm-(.*)\.sh/\1/' | sort | column
	;;
help | --help | -h)
	usage
	;;
"")
	# Interactive mode if no args
	if command -v fzf >/dev/null 2>&1; then
		# Generate a combined list for fzf
		choice=$( (
			find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "install-*.sh" -o -name "install_*.sh" | sed -E 's/.*scripts\/(install[-_].*)\.sh/\1/'
			find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "build-*.sh" | sed -E 's/.*scripts\/(build-.*)\.sh/\1/'
			find "$RIBYNS_ENV/scripts" -maxdepth 1 -name "pm-*.sh" | sed -E 's/.*scripts\/(pm-.*)\.sh/\1/'
		) | fzf --prompt="renv > " --height=40% --reverse --border)
		
		if [[ -n "$choice" ]]; then
			"$RIBYNS_ENV/scripts/${choice}.sh"
		fi
	else
		usage
	fi
	;;
*)
	# Fallback: try to run as a direct script name if it matches nothing else
	if [[ -f "$RIBYNS_ENV/scripts/$1.sh" ]]; then
		script="$RIBYNS_ENV/scripts/$1.sh"
		shift
		"$script" "$@"
	else
		error "Unknown command: $1"
		usage
		exit 1
	fi
	;;
esac
